<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Rovnoměrně zrychlený a zpomalený pohyb</title>
<script>
  window.MathJax = {
    tex: { inlineMath: [['\\(','\\)'], ['$', '$']], displayMath: [['\\[','\\]']] },
    svg: { fontCache: 'global' },
    startup: {
      typeset: false,
      ready: () => {
        MathJax.startup.defaultReady();
        window.mathJaxReady = true;
        if (typeof window.typesetMath === 'function') window.typesetMath();
      }
    }
  };
</script>
<script defer src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"></script>
<style>
:root{
  --bg:#fbf6ee; --panel:#ffffff; --ink:#2b2b2b; --muted:#6f6a63;
  --line:#ead8bf; --accent:#f4bd62; --accent2:#8ccfbd; --ok:#fff2a8;
  --soft:#f7efe3; --bad:#ffe0dd;
}
*{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);font-family:system-ui,-apple-system,"Segoe UI",Arial,sans-serif}
.app{display:grid;grid-template-columns:360px 1fr;min-height:100vh}
aside{padding:18px;border-right:1px solid var(--line);background:#fffaf2;position:sticky;top:0;height:100vh;overflow:auto}
main{padding:22px;overflow:auto}
h1{font-size:25px;margin:0 0 12px} h2{font-size:22px;margin:0 0 12px} h3{font-size:18px;margin:18px 0 8px}
.small{font-size:13px;color:var(--muted);line-height:1.35}.pill{display:inline-block;padding:4px 9px;border-radius:999px;background:var(--soft);border:1px solid var(--line);font-size:12px;margin:2px}
.mode{display:block;width:100%;text-align:left;border:1px solid var(--line);border-radius:15px;background:var(--panel);padding:11px 12px;margin:7px 0;cursor:pointer;font-weight:700;color:var(--ink)}
.mode.active{border-color:var(--accent);box-shadow:0 0 0 3px rgba(244,189,98,.25);background:#fff8e8}
.card{background:var(--panel);border:1px solid var(--line);border-radius:20px;padding:16px;margin:14px 0;box-shadow:0 4px 18px rgba(70,50,20,.05)}
.field{display:grid;grid-template-columns:minmax(120px,1fr) minmax(86px,116px) 48px;gap:8px;align-items:center;margin:8px 0;padding:8px;border-radius:13px;border:1px solid transparent}
.field.unknown{background:#eef9f6;border-color:#8ccfbd}.field.unknown.computed{background:var(--ok);border-color:#ecd25a}.field input[readonly]{background:#fffdf5;font-weight:800;color:#7a4e00}.labelBlock{min-width:0;display:flex;flex-direction:column;gap:6px}.unknownPick{display:inline-flex;align-items:center;align-self:flex-start;gap:6px;font-size:12px;color:#286d60;cursor:pointer;user-select:none;white-space:nowrap;background:#f8fffc;border:1px solid #aee1d1;border-radius:999px;padding:3px 8px;line-height:1.1}.unknownPick input{width:auto;min-width:0;flex:0 0 auto;accent-color:var(--accent2);cursor:pointer;margin:0}
.field.computed{background:var(--ok);border-color:#ecd25a}.field label{font-size:14px;line-height:1.2;min-width:0}.field input{width:100%;min-width:0;padding:9px 8px;border:1px solid var(--line);border-radius:10px;font-size:15px;background:white;color:var(--ink)}
.field input:focus{outline:2px solid rgba(140,207,189,.7);border-color:var(--accent2)}
.unit{font-size:13px;color:var(--muted)}
.btnrow{display:flex;gap:8px;flex-wrap:wrap}.btn{border:1px solid var(--line);background:white;border-radius:12px;padding:9px 11px;cursor:pointer;font-weight:700}.btn:hover{background:#fff8e8}
.resultBox{background:#f8fffc;border:1px solid #aee1d1;border-radius:22px;padding:18px;margin-bottom:16px}.steps{display:grid;gap:12px}.step{background:white;border:1px solid var(--line);border-left:7px solid var(--accent);border-radius:17px;padding:14px;overflow-x:auto}.step b{display:block;margin-bottom:8px}.deriveRows{display:grid;gap:10px;margin-top:8px}.deriveRow{display:grid;grid-template-columns:34px minmax(150px,1fr) 2fr;gap:12px;align-items:center;background:#fffdf9;border:1px solid var(--line);border-radius:14px;padding:10px}.deriveNo{width:26px;height:26px;border-radius:999px;background:#e8f6ef;border:1px solid #aee1d1;display:flex;align-items:center;justify-content:center;font-weight:800;color:#126b42}.deriveText{font-size:14px;color:var(--muted);line-height:1.25}.deriveMath{overflow-x:auto;text-align:center}.warn{background:var(--bad);border:1px solid #f2a29a;border-radius:14px;padding:10px;margin-top:10px}.muted{color:var(--muted)}
@media(max-width:850px){
  .app{grid-template-columns:1fr}
  aside{height:auto;position:relative;border-right:0;border-bottom:1px solid var(--line)}
}
@media(max-width:650px){
  body{font-size:16px}
  aside{padding:14px}
  main{padding:14px}
  h1{font-size:23px}
  h2{font-size:21px;line-height:1.2}
  .resultBox{padding:14px;border-radius:18px}
  .step{padding:12px;border-left-width:6px;border-radius:16px;overflow:hidden}
  .step>b{font-size:19px;line-height:1.25;margin-bottom:10px}
  .step>mjx-container[display="true"]{overflow-x:auto;overflow-y:hidden;max-width:100%;padding:4px 0;-webkit-overflow-scrolling:touch}
  .deriveRows{gap:12px}
  .deriveRow{
    display:grid;
    grid-template-columns:34px 1fr;
    grid-template-areas:"no text" "math math";
    align-items:center;
    gap:8px 10px;
    padding:12px;
  }
  .deriveNo{grid-area:no;width:31px;height:31px;font-size:18px}
  .deriveText{grid-area:text;font-size:16px;line-height:1.28;color:#5d5851}
  .deriveMath{
    grid-area:math;
    width:100%;
    max-width:100%;
    overflow-x:auto;
    overflow-y:hidden;
    text-align:left;
    padding-top:9px;
    border-top:1px dashed var(--line);
    -webkit-overflow-scrolling:touch;
  }
  .deriveMath mjx-container[display="true"]{
    margin:0!important;
    text-align:left!important;
    min-width:max-content;
    max-width:none;
    padding:2px 0 4px;
  }
}
@media(max-width:430px){
  aside{padding:12px}
  main{padding:10px}
  .card{padding:12px;border-radius:16px}
  .field{grid-template-columns:minmax(98px,1fr) minmax(78px,112px) 42px;gap:6px;padding:7px}
  .field label{font-size:13px}
  .small{font-size:12px}
  .field input{font-size:15px;padding:8px 7px}
  .unknownPick{font-size:12px;padding:3px 7px}
  .unit{font-size:12px}
  .btn{padding:9px 10px}
  .step{padding:11px;border-radius:15px}
  .step>b{font-size:18px}
  .deriveRow{padding:11px;border-radius:13px}
  .deriveText{font-size:15px}
}
</style>
</head>
<body>
<div class="app">
<aside>
  <h1>Rovnoměrně zrychlený a zpomalený pohyb</h1>
  <p class="small">Vyber typ úlohy. Můžeš zaškrtnout jednu nebo dvě neznámé. Na začátku jsou vždy jen dvě rovnice: \(v=v_0+a\Delta t\) a \(s=v_0\Delta t+\frac{1}{2}a(\Delta t)^2\). Podle podmínky \(v_0=0\) nebo \(v=0\) se jen zjednoduší. U zrychleného pohybu zadávej \(a\) kladně, u zpomaleného záporně.</p>
  <div id="modes"></div>
  <div class="card">
    <h3>Vstupní veličiny</h3>
    <div id="fields"></div>
    <div class="btnrow">
      <button class="btn" id="randomExample">Generovat náhodný příklad</button>
      <button class="btn" id="clearAll">Smazat vše</button>
    </div>
  </div>
</aside>
<main>
  <div class="resultBox">
    <h2 id="status">Zadej hodnoty</h2>
    <div id="equation" class="muted"></div>
  </div>
  <div class="steps" id="steps"></div>
</main>
</div>
<script>
const modes = [
 {id:'accelZero', name:'1) Zrychlený pohyb, v₀ = 0', sign:1, fixedV0:0, fixedV:null},
 {id:'decelStop', name:'2) Zpomalený pohyb, v = 0', sign:-1, fixedV0:null, fixedV:0},
 {id:'accelV0', name:'3) Zrychlený pohyb, v₀ ≠ 0', sign:1, fixedV0:null, fixedV:null},
 {id:'decelV0', name:'4) Zpomalený pohyb, v ≠ 0', sign:-1, fixedV0:null, fixedV:null}
];

const labels = {
  v0:['v₀','m·s⁻¹','počáteční rychlost'],
  a:['a','m·s⁻²','zrychlení'],
  v:['v','m·s⁻¹','okamžitá rychlost po čase Δt'],
  dt:['Δt','s','čas pohybu'],
  s:['s','m','dráha / posunutí']
};
const visible = {
  accelZero:['a','dt','v','s'],
  decelStop:['v0','a','dt','s'],
  accelV0:['v0','a','dt','v','s'],
  decelV0:['v0','a','dt','v','s']
};
let mode='accelZero';
const values = {};
const computed = {};
let typingTimer=null;
const unknownsByMode = {
  accelZero:['v'],
  decelStop:['s'],
  accelV0:['v'],
  decelV0:['v']
};
const $ = id => document.getElementById(id);

function cfg(){ return modes.find(m=>m.id===mode); }
function visibleKeys(){ return visible[mode] || []; }
function currentUnknowns(){
  const keys=visibleKeys();
  let arr=(unknownsByMode[mode]||[]).filter(k=>keys.includes(k));
  if(arr.length===0) arr=[keys.includes('v')?'v':keys[0]];
  if(arr.length>2) arr=arr.slice(-2);
  unknownsByMode[mode]=arr;
  return arr;
}
function selectUnknown(k, checked){
  const keys=visibleKeys();
  let arr=currentUnknowns().slice();
  if(checked){
    arr=arr.filter(x=>x!==k);
    arr.push(k);
    if(arr.length>2) arr.shift();
  }else{
    arr=arr.filter(x=>x!==k);
    if(arr.length===0) arr=[k];
  }
  unknownsByMode[mode]=arr.filter(x=>keys.includes(x));
  for(const key of keys){
    if(!unknownsByMode[mode].includes(key) && computed[key]){
      delete computed[key];
    }
    if(unknownsByMode[mode].includes(key)){
      delete values[key];
      delete computed[key];
    }
  }
  renderFields();
  calculate();
}
function fmt(x,d=2){
  if(!isFinite(x)) return '';
  return Number(x).toLocaleString('cs-CZ',{maximumFractionDigits:d,minimumFractionDigits:0}).replace(/\s/g,'\u202f');
}
function latexNum(x,d=2){ return fmt(x,d).replace(',', '{,}'); }
function latexTerm(x,d=2){ const s=latexNum(x,d); return Number(x)<0 ? `\\left(${s}\\right)` : s; }
function nice(v,d=2){ return String(Math.round(v*Math.pow(10,d))/Math.pow(10,d)).replace('.',','); }
function val(k){
  const v = parseFloat(String(values[k]??'').replace(',','.'));
  return Number.isFinite(v)?v:null;
}
function signedNumber(x,d=2){
  if(x==null || !Number.isFinite(x)) return 'a';
  return x>0 ? `+${latexNum(x,d)}` : latexTerm(x,d);
}
function signedA(){
  const a=val('a');
  if(a==null || !Number.isFinite(a)) return '+a';
  return `+${latexTerm(a,2)}`;
}
function aSignProblem(a){
  if(a==null || currentUnknowns().includes('a')) return '';
  if(cfg().sign>0 && a<=0) return 'U zrychleného pohybu má být zrychlení kladné.';
  if(cfg().sign<0 && a>=0) return 'U zpomaleného pohybu má být zrychlení záporné.';
  return '';
}
function motionState(){
  const a=val('a');
  const fixed=cfg().fixedV0;
  const fixedV=cfg().fixedV;
  return {
    a,
    fixedV0: fixed,
    fixedV,
    v0: fixed===null ? val('v0') : fixed,
    dt: val('dt'),
    v: fixedV===null ? val('v') : fixedV,
    s: val('s')
  };
}
function setComputed(k,v){
  if(!currentUnknowns().includes(k)) return false;
  if(isFinite(v)){
    values[k]=nice(v,2);
    computed[k]=true;
    return true;
  }
  return false;
}
function clearSelectedComputed(){
  for(const k of currentUnknowns()){
    if(computed[k]){ delete values[k]; delete computed[k]; }
  }
}
function clearAll(){
  for(const k in values) delete values[k];
  for(const k in computed) delete computed[k];
  renderFields();
  calculate();
}
function renderModes(){
  $('modes').innerHTML=modes.map(m=>`<button class="mode ${m.id===mode?'active':''}" data-mode="${m.id}">${m.name}</button>`).join('');
  document.querySelectorAll('.mode').forEach(b=>b.onclick=()=>{
    mode=b.dataset.mode;
    currentUnknowns();
    for(const k in computed){ delete values[k]; delete computed[k]; }
    renderModes();
    renderFields();
    calculate();
  });
}
function renderFields(){
 const keys=visibleKeys();
 const u=currentUnknowns();
 $('fields').innerHTML=keys.map(k=>{
   const l=labels[k];
   const checked = u.includes(k) ? ' checked' : '';
   const readOnly = u.includes(k) ? ' readonly' : '';
   const placeholder = u.includes(k) ? 'neznámá' : '?';
   return `<div class="field ${u.includes(k)?'unknown':''} ${computed[k]?'computed':''}" id="row_${k}"><div class="labelBlock"><label for="${k}"><b>${l[0]}</b><br><span class="small">${l[2]}</span></label><label class="unknownPick" title="Označit ${l[0]} jako neznámou"><input type="checkbox" data-unknown="${k}"${checked}><span>neznámá</span></label></div><input inputmode="decimal" id="${k}" value="${values[k]??''}" placeholder="${placeholder}" autocomplete="off"${readOnly}><span class="unit">${l[1]}</span></div>`;
 }).join('');
 keys.forEach(k=>{
   const input=$(k);
   const box=document.querySelector(`input[data-unknown="${k}"]`);
   box.addEventListener('change',e=>selectUnknown(k,e.target.checked));
   if(u.includes(k)) return;
   input.addEventListener('input',e=>{
     values[k]=e.target.value;
     computed[k]=false;
     clearSelectedComputed();
     clearTimeout(typingTimer);
     typingTimer=setTimeout(calculate,80);
   });
 });
}
function variableLatex(k){
 const map={v0:'v_0',a:'a',v:'v',dt:'\\Delta t',s:'s'};
 return map[k] || k;
}
function unitLatex(k){
 const unit=labels[k]?.[1] || '';
 if(!unit) return '';
 const map={'m·s⁻¹':'m\\cdot s^{-1}', 'm·s⁻²':'m\\cdot s^{-2}', 's':'s', 'm':'m'};
 return `\\,\\mathrm{${map[unit] || unit}}`;
}
function hasZeroV0(){ return cfg().fixedV0===0; }
function hasZeroV(){ return cfg().fixedV===0; }
function baseEquationHtml(){
  return `\\[v=v_0+a\\Delta t\\]\\[s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2\\]`;
}
function simplificationHtml(){
  if(hasZeroV0()){
    return `<div class="step"><b>2) Zjednodušení pro \\(v_0=0\\)</b><p class="small">Do obou hlavních rovnic dosadíme pouze počáteční podmínku. Žádný nový vzorec nepřidáváme.</p>\\[v=a\\Delta t\\]\\[s=\\frac{1}{2}a(\\Delta t)^2\\]</div>`;
  }
  if(hasZeroV()){
    return `<div class="step"><b>2) Zjednodušení pro \\(v=0\\)</b><p class="small">Do rovnice pro rychlost dosadíme pouze podmínku zastavení. Rovnice pro dráhu zůstává stejná.</p>\\[0=v_0+a\\Delta t\\]\\[s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2\\]</div>`;
  }
  return '';
}
function derivationHtml(rows){
 return `<div class="deriveRows">` + rows.map((row,i)=>`<div class="deriveRow"><div class="deriveNo">${i+1}</div><div class="deriveText">${row.txt}</div><div class="deriveMath">\\[${row.eq}\\]</div></div>`).join('') + `</div>`;
}
function oneUnknownRows(x){
  const a=signedA();
  const aPlain = val('a')==null ? 'a' : latexTerm(val('a'),2);
  if(x==='a'){
    if(hasZeroV0()){
      return [
        {txt:'Vyjdeme ze zjednodušené rovnice pro rychlost', eq:'v=a\\Delta t'},
        {txt:'Vydělíme časem \\(\\Delta t\\)', eq:'a=\\frac{v}{\\Delta t}'}
      ];
    }
    if(hasZeroV()){
      return [
        {txt:'Vyjdeme z rovnice pro rychlost při zastavení', eq:'0=v_0+a\\Delta t'},
        {txt:'Odečteme \\(v_0\\) od obou stran', eq:'-v_0=a\\Delta t'},
        {txt:'Vydělíme časem \\(\\Delta t\\)', eq:'a=-\\frac{v_0}{\\Delta t}'}
      ];
    }
    return [
      {txt:'Vezmeme rovnici pro rychlost, protože je v ní jediná neznámá \\(a\\)', eq:'v=v_0+a\\Delta t'},
      {txt:'Odečteme \\(v_0\\) od obou stran', eq:'v-v_0=a\\Delta t'},
      {txt:'Vydělíme časem \\(\\Delta t\\) a pak dosadíme hodnoty', eq:'a=\\frac{v-v_0}{\\Delta t}'}
    ];
  }
  if(x==='v'){
    if(hasZeroV0()){
      return [
        {txt:'Vyjdeme ze zjednodušené rovnice pro rychlost', eq:'v=a\\Delta t'},
        {txt:'Dosadíme zadané zrychlení', eq:`v=${aPlain}\\cdot \\Delta t`}
      ];
    }
    return [
      {txt:'Vezmeme rovnici pro rychlost, protože je v ní jediná neznámá \\(v\\)', eq:'v=v_0+a\\Delta t'},
      {txt:'Dosadíme známé hodnoty a dopočítáme \\(v\\)', eq:`v=v_0${a}\\cdot \\Delta t`}
    ];
  }
  if(x==='s'){
    if(hasZeroV0()){
      return [
        {txt:'Vyjdeme ze zjednodušené rovnice pro dráhu', eq:'s=\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Dosadíme zadané zrychlení', eq:`s=\\frac{1}{2}\\cdot ${aPlain}\\cdot (\\Delta t)^2`}
      ];
    }
    return [
      {txt:'Vezmeme rovnici pro dráhu, protože je v ní jediná neznámá \\(s\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Dosadíme známé hodnoty a dopočítáme \\(s\\)', eq:`s=v_0\\Delta t+\\frac{1}{2}\\cdot ${aPlain}\\cdot (\\Delta t)^2`}
    ];
  }
  if(x==='dt'){
    if(hasZeroV0()){
      return [
        {txt:'Vyjdeme ze zjednodušené rovnice pro dráhu', eq:'s=\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Vynásobíme rovnici dvěma', eq:'2s=a(\\Delta t)^2'},
        {txt:'Vydělíme zrychlením \\(a\\)', eq:'\\frac{2s}{a}=(\\Delta t)^2'},
        {txt:'Odmocníme a vezmeme kladný čas', eq:'\\Delta t=\\sqrt{\\frac{2s}{a}}'}
      ];
    }
    if(hasZeroV()){
      return [
        {txt:'Vyjdeme z rovnice pro rychlost při zastavení', eq:'0=v_0+a\\Delta t'},
        {txt:'Odečteme \\(v_0\\) od obou stran', eq:'-v_0=a\\Delta t'},
        {txt:'Vydělíme zrychlením \\(a\\)', eq:'\\Delta t=-\\frac{v_0}{a}'}
      ];
    }
    return [
      {txt:'Vezmeme rovnici pro rychlost, protože je v ní jediná neznámá \\(\\Delta t\\)', eq:'v=v_0+a\\Delta t'},
      {txt:'Odečteme \\(v_0\\) od obou stran', eq:'v-v_0=a\\Delta t'},
      {txt:'Vydělíme zrychlením \\(a\\)', eq:'\\Delta t=\\frac{v-v_0}{a}'},
      {txt:'Dosadíme známé hodnoty a dopočítáme čas', eq:`\\Delta t=\\frac{v-v_0}{${aPlain}}`}
    ];
  }
  if(x==='v0'){
    if(hasZeroV()){
      return [
        {txt:'Vyjdeme z rovnice pro rychlost při zastavení', eq:'0=v_0+a\\Delta t'},
        {txt:'Odečteme \\(a\\Delta t\\) od obou stran', eq:'v_0=-a\\Delta t'}
      ];
    }
    return [
      {txt:'Vezmeme rovnici pro rychlost, protože je v ní jediná neznámá \\(v_0\\)', eq:'v=v_0+a\\Delta t'},
      {txt:'Odečteme \\(a\\Delta t\\) od obou stran', eq:'v-a\\Delta t=v_0'},
      {txt:'Zapíšeme \\(v_0\\) vlevo', eq:'v_0=v-a\\Delta t'},
      {txt:'Dosadíme známé hodnoty a dopočítáme počáteční rychlost', eq:`v_0=v-${aPlain}\\cdot \\Delta t`}
    ];
  }
  return [];
}
function twoUnknownRows(pair){
  const p=pair.slice().sort((a,b)=>visibleKeys().indexOf(a)-visibleKeys().indexOf(b)).join(',');
  const aPlain = val('a')==null ? 'a' : latexTerm(val('a'),2);
  if(p==='a,v'){
    if(hasZeroV0()){
      return [
        {txt:'Nejdřív vezmeme rovnici pro dráhu, protože je v ní jediná neznámá \\(a\\)', eq:'s=\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Vyjádříme zrychlení', eq:'a=\\frac{2s}{(\\Delta t)^2}'},
        {txt:'Dosadíme a spočítáme \\(a\\). Pak vezmeme druhou rovnici', eq:'v=a\\Delta t'},
        {txt:'Do druhé rovnice dosadíme vypočítané \\(a\\) a dopočítáme \\(v\\)', eq:'v=a\\Delta t'}
      ];
    }
    return [
      {txt:'Nejdřív vezmeme rovnici pro dráhu, protože je v ní jediná neznámá \\(a\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Odečteme \\(v_0\\Delta t\\) od obou stran', eq:'s-v_0\\Delta t=\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Vyjádříme zrychlení', eq:'a=\\frac{2(s-v_0\\Delta t)}{(\\Delta t)^2}'},
      {txt:'Dosadíme a spočítáme \\(a\\). Pak vezmeme rovnici pro rychlost', eq:'v=v_0+a\\Delta t'},
      {txt:'Do ní dosadíme vypočítané \\(a\\) a dopočítáme \\(v\\)', eq:'v=v_0+a\\Delta t'}
    ];
  }
  if(p==='a,s'){
    if(hasZeroV()){
      return [
        {txt:'Nejdřív vezmeme rovnici pro rychlost, protože je v ní jediná neznámá \\(a\\)', eq:'0=v_0+a\\Delta t'},
        {txt:'Vyjádříme zrychlení', eq:'a=-\\frac{v_0}{\\Delta t}'},
        {txt:'Dosadíme a spočítáme \\(a\\). Pak vezmeme rovnici pro dráhu', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Do ní dosadíme vypočítané \\(a\\) a dopočítáme \\(s\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'}
      ];
    }
    if(hasZeroV0()){
      return [
        {txt:'Nejdřív vezmeme rovnici pro rychlost, protože je v ní jediná neznámá \\(a\\)', eq:'v=a\\Delta t'},
        {txt:'Vyjádříme zrychlení', eq:'a=\\frac{v}{\\Delta t}'},
        {txt:'Dosadíme a spočítáme \\(a\\). Pak vezmeme rovnici pro dráhu', eq:'s=\\frac{1}{2}a(\\Delta t)^2'},
