    if(hasZeroV()){
      return [
        {txt:'Tady není žádná rovnice jen s jednou neznámou, proto musíme dosadit jednu rovnici do druhé', eq:'0=v_0+a\\Delta t,\\quad s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Z rovnice pro rychlost vyjádříme zrychlení', eq:'a=-\\frac{v_0}{\\Delta t}'},
        {txt:'Dosadíme do rovnice pro dráhu', eq:'s=v_0\\Delta t+\\frac{1}{2}\\left(-\\frac{v_0}{\\Delta t}\\right)(\\Delta t)^2'},
        {txt:'Upravíme pravou stranu', eq:'s=\\frac{1}{2}v_0\\Delta t'},
        {txt:'Vyjádříme čas', eq:'\\Delta t=\\frac{2s}{v_0}'},
        {txt:'Potom dopočítáme zrychlení z první rovnice', eq:'a=-\\frac{v_0}{\\Delta t}'}
      ];
    }
    return [
      {txt:'Tady není žádná rovnice jen s jednou neznámou, proto musíme dosadit jednu rovnici do druhé', eq:'v=v_0+a\\Delta t,\\quad s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Z rovnice pro rychlost vyjádříme zrychlení', eq:'a=\\frac{v-v_0}{\\Delta t}'},
      {txt:'Dosadíme do rovnice pro dráhu', eq:'s=v_0\\Delta t+\\frac{1}{2}\\cdot\\frac{v-v_0}{\\Delta t}\\cdot(\\Delta t)^2'},
      {txt:'Upravíme výraz', eq:'s=v_0\\Delta t+\\frac{1}{2}(v-v_0)\\Delta t'},
      {txt:'Vyjádříme čas', eq:'\\Delta t=\\frac{2s}{v_0+v}'},
