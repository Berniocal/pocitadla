        {txt:'Pak vezmeme druhou rovnici, kde je jediná neznámá \\(s\\)', eq:'s=\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Dosadíme a spočítáme \\(s\\)', eq:`s=\\frac{1}{2}\\cdot ${aPlain}\\cdot (\\Delta t)^2`}
      ];
    }
    return [
      {txt:'Nejdřív vezmeme rovnici pro rychlost, protože je v ní jediná neznámá \\(v\\)', eq:'v=v_0+a\\Delta t'},
      {txt:'Dosadíme známé hodnoty a spočítáme \\(v\\)', eq:`v=v_0${signedA()}\\Delta t`},
      {txt:'Pak vezmeme rovnici pro dráhu, protože je v ní jediná neznámá \\(s\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Dosadíme známé hodnoty a spočítáme \\(s\\)', eq:`s=v_0\\Delta t+\\frac{1}{2}\\cdot ${aPlain}(\\Delta t)^2`}
    ];
  }
  if(p==='dt,v'){
    if(hasZeroV0()){
      return [
        {txt:'Nejdřív vezmeme rovnici pro dráhu, protože je v ní jediná neznámá \\(\\Delta t\\)', eq:'s=\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Vynásobíme rovnici dvěma', eq:'2s=a(\\Delta t)^2'},
        {txt:'Vydělíme zrychlením \\(a\\)', eq:'\\frac{2s}{a}=(\\Delta t)^2'},
        {txt:'Odmocníme, vezmeme kladný čas a dosadíme hodnoty', eq:'\\Delta t=\\sqrt{\\frac{2s}{a}}'},
        {txt:'Pak vezmeme rovnici pro rychlost a dosadíme vypočítaný čas', eq:'v=a\\Delta t'}
      ];
    }
    return [
      {txt:'Nejdřív vezmeme rovnici pro dráhu, protože je v ní jediná neznámá \\(\\Delta t\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Protože čas je i ve druhé mocnině, vznikne kvadratická rovnice', eq:'\\frac{1}{2}a(\\Delta t)^2+v_0\\Delta t-s=0'},
      {txt:'Porovnáme s obecným tvarem kvadratické rovnice', eq:'a(\\Delta t)^2+b\\Delta t+c=0'},
      {txt:'Dosadíme do vzorce pro kořeny', eq:'\\Delta t_{1,2}=\\frac{-b\\pm\\sqrt{b^2-4ac}}{2a}'},
      {txt:'Vybereme kladný čas. Pak vezmeme rovnici pro rychlost', eq:'v=v_0+a\\Delta t'},
      {txt:'Do ní dosadíme vypočítaný čas a dopočítáme \\(v\\)', eq:'v=v_0+a\\Delta t'}
    ];
  }
  if(p==='dt,s'){
    if(hasZeroV0()){
      return [
        {txt:'Nejdřív vezmeme rovnici pro rychlost, protože je v ní jediná neznámá \\(\\Delta t\\)', eq:'v=a\\Delta t'},
        {txt:'Vyjádříme čas', eq:'\\Delta t=\\frac{v}{a}'},
        {txt:'Dosadíme a spočítáme \\(\\Delta t\\). Pak vezmeme rovnici pro dráhu', eq:'s=\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Do ní dosadíme vypočítaný čas a dopočítáme \\(s\\)', eq:'s=\\frac{1}{2}a(\\Delta t)^2'}
      ];
    }
    if(hasZeroV()){
      return [
        {txt:'Nejdřív vezmeme rovnici pro rychlost při zastavení, protože je v ní jediná neznámá \\(\\Delta t\\)', eq:'0=v_0+a\\Delta t'},
        {txt:'Vyjádříme čas', eq:'\\Delta t=-\\frac{v_0}{a}'},
        {txt:'Dosadíme a spočítáme \\(\\Delta t\\). Pak vezmeme rovnici pro dráhu', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Do ní dosadíme vypočítaný čas a dopočítáme \\(s\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'}
      ];
    }
    return [
      {txt:'Nejdřív vezmeme rovnici pro rychlost, protože je v ní jediná neznámá \\(\\Delta t\\)', eq:'v=v_0+a\\Delta t'},
      {txt:'Odečteme \\(v_0\\) a vydělíme zrychlením', eq:'\\Delta t=\\frac{v-v_0}{a}'},
      {txt:'Dosadíme a spočítáme \\(\\Delta t\\). Pak vezmeme rovnici pro dráhu', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Do ní dosadíme vypočítaný čas a dopočítáme \\(s\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'}
    ];
  }
  if(p==='v0,v'){
    return [
      {txt:'Nejdřív vezmeme rovnici pro dráhu, protože je v ní jediná neznámá \\(v_0\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Odečteme člen s druhou mocninou času', eq:'s-\\frac{1}{2}a(\\Delta t)^2=v_0\\Delta t'},
      {txt:'Vydělíme časem', eq:'v_0=\\frac{s-\\frac{1}{2}a(\\Delta t)^2}{\\Delta t}'},
      {txt:'Dosadíme a spočítáme \\(v_0\\). Pak vezmeme rovnici pro rychlost', eq:'v=v_0+a\\Delta t'},
      {txt:'Do ní dosadíme vypočítané \\(v_0\\) a dopočítáme \\(v\\)', eq:'v=v_0+a\\Delta t'}
    ];
  }
  if(p==='v0,s'){
    if(hasZeroV()){
      return [
        {txt:'Nejdřív vezmeme rovnici pro rychlost při zastavení, protože je v ní jediná neznámá \\(v_0\\)', eq:'0=v_0+a\\Delta t'},
        {txt:'Odečteme \\(a\\Delta t\\) od obou stran', eq:'v_0=-a\\Delta t'},
        {txt:'Dosadíme a spočítáme \\(v_0\\). Pak vezmeme rovnici pro dráhu', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Do ní dosadíme vypočítané \\(v_0\\) a dopočítáme \\(s\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'}
      ];
    }
    return [
      {txt:'Nejdřív vezmeme rovnici pro rychlost, protože je v ní jediná neznámá \\(v_0\\)', eq:'v=v_0+a\\Delta t'},
      {txt:'Odečteme \\(a\\Delta t\\) od obou stran', eq:'v_0=v-a\\Delta t'},
      {txt:'Dosadíme a spočítáme \\(v_0\\). Pak vezmeme rovnici pro dráhu', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Do ní dosadíme vypočítané \\(v_0\\) a dopočítáme \\(s\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'}
    ];
  }
  if(p==='v0,dt'){
    if(hasZeroV()){
      return [
        {txt:'Tady není žádná rovnice jen s jednou neznámou, proto musíme dosadit jednu rovnici do druhé', eq:'0=v_0+a\\Delta t,\\quad s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Z rovnice pro rychlost vyjádříme \\(v_0\\)', eq:'v_0=-a\\Delta t'},
        {txt:'Dosadíme do rovnice pro dráhu', eq:'s=-\\frac{1}{2}a(\\Delta t)^2'},
        {txt:'Vyjádříme čas', eq:'\\Delta t=\\sqrt{-\\frac{2s}{a}}'},
        {txt:'Potom dopočítáme počáteční rychlost', eq:'v_0=-a\\Delta t'}
      ];
    }
    return [
      {txt:'Tady není žádná rovnice jen s jednou neznámou, proto musíme dosadit jednu rovnici do druhé', eq:'v=v_0+a\\Delta t,\\quad s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Z rovnice pro rychlost vyjádříme \\(v_0\\)', eq:'v_0=v-a\\Delta t'},
      {txt:'Dosadíme do rovnice pro dráhu', eq:'s=(v-a\\Delta t)\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Upravíme na kvadratickou rovnici pro čas', eq:'\\frac{1}{2}a(\\Delta t)^2-v\\Delta t+s=0'},
      {txt:'Porovnáme s obecným tvarem kvadratické rovnice', eq:'a(\\Delta t)^2+b\\Delta t+c=0'},
      {txt:'Dosadíme do vzorce pro kořeny', eq:'\\Delta t_{1,2}=\\frac{-b\\pm\\sqrt{b^2-4ac}}{2a}'},
      {txt:'Vybereme kladný čas a nakonec dopočítáme \\(v_0\\)', eq:'v_0=v-a\\Delta t'}
    ];
  }
  return [];
}
function sortedPairKey(pair){
  return pair.slice().sort((x,y)=>visibleKeys().indexOf(x)-visibleKeys().indexOf(y)).join(',');
}
function calculationOrder(pair){
  const p=sortedPairKey(pair);
  if(p==='a,dt') return ['dt','a'];
  if(p==='v0,a') return ['a','v0'];
  if(p==='v0,dt') return ['dt','v0'];
  return p.split(',');
}
function formulaStartsWithVar(formula, variable){
  const f=formula.replace(/\s/g,'');
  if(variable==='dt') return f.startsWith('\\Deltat=');
  if(variable==='v0') return f.startsWith('v_0=');
  if(variable==='a') return f.startsWith('a=');
  if(variable==='v') return f.startsWith('v=');
  if(variable==='s') return f.startsWith('s=');
  return false;
}
function rowExpressesVar(row, variable){
  return formulaStartsWithVar(row.eq || '', variable);
}
function displayFormulaList(html){
  return [...html.matchAll(/\\\[([\s\S]*?)\\\]/g)].map(m=>m[1]);
}
function isCalculationPlaceholder(row){
  const txt=row.txt || '';
  return txt.includes('Dosadíme a spočítáme') ||
         txt.includes('Dosadíme známé hodnoty a spočítáme') ||
         txt.includes('Do ní dosadíme vypočítané') ||
         txt.includes('Do ní dosadíme vypočítaný') ||
         txt.includes('Do druhé rovnice dosadíme vypočítané');
}
function nextFormulaForVar(formulas, variable, startIndex){
  for(let i=startIndex;i<formulas.length;i++){
    if(formulaStartsWithVar(formulas[i], variable)) return {formula:formulas[i], next:i+1};
  }
  return {formula:null, next:startIndex};
}
function twoUnknownWorkedRows(unknowns, r){
  const p=sortedPairKey(unknowns);
  if(!hasZeroV0() && !hasZeroV() && (p==='dt,v' || p==='v0,dt')){
    return quadraticWorkedRows(p, r);
  }
  const symbolicRows=twoUnknownRows(unknowns);
  const formulas=displayFormulaList(substitutionHtml(unknowns, r));
  const order=calculationOrder(unknowns);
  const rows=[];
  let formulaIndex=0;
  let orderIndex=0;

  for(const row of symbolicRows){
    const variable=order[orderIndex];
    const placeholder=isCalculationPlaceholder(row);
    if(placeholder && (!variable || !rowExpressesVar(row, variable))) continue;
    const visibleRow=placeholder && variable
      ? {txt:`Teď vezmeme rovnici pro \\(${labels[variable][0]}\\)`, eq:row.eq}
      : row;
    rows.push(visibleRow);
    if(variable && rowExpressesVar(row, variable)){
      const found=nextFormulaForVar(formulas, variable, formulaIndex);
      if(found.formula){
        rows.push({
          txt:`Dosadíme hodnoty a spočítáme \\(${labels[variable][0]}\\)`,
          eq:found.formula
        });
        formulaIndex=found.next;
        orderIndex++;
      }
    }
  }
  return rows;
}
function signedQuadTerm(x, body=''){
  if(Math.abs(x)<1e-12) return '';
  const sign=x<0 ? '-' : '+';
  return `${sign}${latexNum(Math.abs(x))}${body}`;
}
function quadraticPolynomial(A,B,C){
  return `${latexTerm(A)}(\\Delta t)^2${signedQuadTerm(B,'\\Delta t')}${signedQuadTerm(C)}=0`;
}
function quadraticFormulaRows(A,B,C, chosen){
  const roots=solveQuadratic(A,B,C);
  const r1=roots[0], r2=roots[1] ?? roots[0];
  return [
    {txt:'Tady si zapíšeme koeficienty \\(a\\), \\(b\\), \\(c\\) kvadratické rovnice', eq:`a=${latexNum(A)},\\quad b=${latexNum(B)},\\quad c=${latexNum(C)}`},
    {txt:'Dosadíme je do vzorce pro kvadratickou rovnici', eq:`\\Delta t_{1,2}=\\frac{-${latexTerm(B)}\\pm\\sqrt{${latexTerm(B)}^2-4\\cdot ${latexTerm(A)}\\cdot ${latexTerm(C)}}}{2\\cdot ${latexTerm(A)}}`},
    {txt:'Spočítáme oba kořeny', eq:`\\Delta t_1=${latexNum(r1)}\\,\\mathrm{s},\\quad \\Delta t_2=${latexNum(r2)}\\,\\mathrm{s}`},
    {txt:'Vybereme kladný čas', eq:`\\Delta t=${latexNum(chosen)}\\,\\mathrm{s}`}
  ];
}
function quadraticWorkedRows(pairKey, r){
  const n=(x,d=2)=>latexNum(x,d);
  const t=x=>latexTerm(x,2);
  const v0=t(r.v0), a=t(r.a), dt=t(r.dt), v=t(r.v), s=t(r.s);
  const speedResult=`v=v_0+a\\Delta t=${v0}+${a}\\cdot ${dt}=${n(r.v)}${unitLatex('v')}`;
  const v0Result=`v_0=v-a\\Delta t=${v}-${a}\\cdot ${dt}=${n(r.v0)}${unitLatex('v0')}`;
  if(pairKey==='dt,v'){
    const A=0.5*r.a, B=r.v0, C=-r.s;
    return [
      {txt:'Nejdřív vezmeme rovnici pro dráhu, protože v ní je jen jedna neznámá \\(\\Delta t\\)', eq:'s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
      {txt:'Dosadíme čísla za všechno kromě času', eq:`${s}=${v0}\\Delta t+\\frac{1}{2}\\cdot ${a}(\\Delta t)^2`},
      {txt:'Převedeme ji na kvadratickou rovnici', eq:quadraticPolynomial(A,B,C)},
      ...quadraticFormulaRows(A,B,C,r.dt),
      {txt:'Teď vezmeme rovnici pro rychlost', eq:'v=v_0+a\\Delta t'},
      {txt:'Dosadíme vypočítaný čas a spočítáme \\(v\\)', eq:speedResult}
    ];
  }
  const A=0.5*r.a, B=-r.v, C=r.s;
  return [
    {txt:'Tady není žádná rovnice jen s jednou neznámou, proto musíme dosadit jednu rovnici do druhé', eq:'v=v_0+a\\Delta t,\\quad s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
    {txt:'Z rovnice pro rychlost vyjádříme \\(v_0\\)', eq:'v_0=v-a\\Delta t'},
    {txt:'Dosadíme do rovnice pro dráhu', eq:'s=(v-a\\Delta t)\\Delta t+\\frac{1}{2}a(\\Delta t)^2'},
    {txt:'Dosadíme čísla za všechno kromě času', eq:`${s}=(${v}-${a}\\Delta t)\\Delta t+\\frac{1}{2}\\cdot ${a}(\\Delta t)^2`},
    {txt:'Převedeme ji na kvadratickou rovnici', eq:quadraticPolynomial(A,B,C)},
    ...quadraticFormulaRows(A,B,C,r.dt),
    {txt:'Teď vezmeme vyjádřený vztah pro \\(v_0\\)', eq:'v_0=v-a\\Delta t'},
    {txt:'Dosadíme vypočítaný čas a spočítáme \\(v_0\\)', eq:v0Result}
  ];
}
function positiveRoot(roots){
  const real=roots.filter(x=>Number.isFinite(x));
  const positive=real.filter(x=>x>=0);
  if(positive.length) return Math.min(...positive);
  return real.length ? real[0] : null;
}
function solveQuadratic(A,B,C){
  if(Math.abs(A)<1e-12){
    if(Math.abs(B)<1e-12) return [];
    return [-C/B];
  }
  const D=B*B-4*A*C;
  if(D<-1e-9) return [];
  if(Math.abs(D)<1e-9) return [-B/(2*A)];
  const sqrtD=Math.sqrt(Math.max(0,D));
  return [(-B-sqrtD)/(2*A), (-B+sqrtD)/(2*A)];
}
function knownValue(k, state){
  if(k==='v0') return state.v0;
  return state[k];
}
function missingInputs(unknowns){
  const state=motionState();
  return visibleKeys().filter(k=>!unknowns.includes(k) && knownValue(k,state)==null);
}
function solveMotion(){
  const unknowns=currentUnknowns();
  for(const k of unknowns){ if(computed[k]){ delete values[k]; delete computed[k]; } }
  const miss=missingInputs(unknowns);
  const steps=[];
  const fixedNote = cfg().fixedV0===0 ? ' V dalším kroku použijeme podmínku \\(v_0=0\\).' : (cfg().fixedV===0 ? ' V dalším kroku použijeme podmínku \\(v=0\\).' : '');
  steps.push(`<div class="step"><b>1) Použité rovnice</b>${baseEquationHtml()}<p class="small">Toto jsou vždy dvě hlavní rovnice pro rovnoměrně zrychlený nebo zpomalený pohyb.${fixedNote}</p></div>`);
  const simplified = simplificationHtml();
  if(simplified) steps.push(simplified);
  if(miss.length) return {ready:false, steps, missingInputs:miss, solved:[]};

  const state=motionState();
  const signProblem=aSignProblem(state.a);
  if(signProblem){
    steps.push(`<div class="warn">${signProblem}</div>`);
    return {ready:false, steps, missingInputs:[], solved:[]};
  }
  let a=state.a;
  let v0=state.v0, dt=state.dt, v=state.v, s=state.s;
  let ok=true;

  if(unknowns.length===1){
    const x=unknowns[0];
    if(x==='a') a=(v-v0)/dt;
    if(x==='v') v=v0+a*dt;
    if(x==='s') s=v0*dt+0.5*a*dt*dt;
    if(x==='dt') dt=hasZeroV0() ? Math.sqrt((2*s)/a) : (v-v0)/a;
    if(x==='v0') v0=v-a*dt;
  }else{
    const pair=unknowns.slice().sort((x,y)=>visibleKeys().indexOf(x)-visibleKeys().indexOf(y)).join(',');
    if(pair==='a,v'){
      if(Math.abs(dt)<1e-12) ok=false;
      a=2*(s-v0*dt)/(dt*dt);
      v=v0+a*dt;
    }else if(pair==='a,s'){
      if(Math.abs(dt)<1e-12) ok=false;
      a=(v-v0)/dt;
      s=v0*dt+0.5*a*dt*dt;
    }else if(pair==='a,dt'){
      if(Math.abs(v0+v)<1e-12) ok=false;
      dt=2*s/(v0+v);
      a=(v-v0)/dt;
    }else if(pair==='v0,a'){
      if(Math.abs(dt)<1e-12) ok=false;
      a=2*(v*dt-s)/(dt*dt);
      v0=v-a*dt;
    }else if(pair==='v,s'){
      v=v0+a*dt;
      s=v0*dt+0.5*a*dt*dt;
    }else if(pair==='dt,v'){
      dt=positiveRoot(solveQuadratic(0.5*a, v0, -s));
      if(dt==null) ok=false;
      v=v0+a*dt;
    }else if(pair==='dt,s'){
      dt=(v-v0)/a;
      s=v0*dt+0.5*a*dt*dt;
    }else if(pair==='v0,v'){
      if(Math.abs(dt)<1e-12) ok=false;
      v0=(s-0.5*a*dt*dt)/dt;
      v=v0+a*dt;
    }else if(pair==='v0,s'){
      v0=v-a*dt;
      s=v0*dt+0.5*a*dt*dt;
    }else if(pair==='v0,dt'){
      dt=positiveRoot(solveQuadratic(0.5*a, -v, s));
      if(dt==null) ok=false;
      v0=v-a*dt;
    }else{
      ok=false;
    }
  }
  const solvedValues={v0,a,dt,v,s};
  if(!ok || unknowns.some(k=>!Number.isFinite(solvedValues[k]))){
    steps.push(`<div class="warn">Tahle kombinace hodnot nedává reálné jednoznačné řešení. Zkus upravit zadané hodnoty nebo vybrat jinou dvojici neznámých.</div>`);
    return {ready:false, steps, missingInputs:[], solved:[]};
  }
  if((cfg().sign>0 && solvedValues.a<=0) || (cfg().sign<0 && solvedValues.a>=0)){
    steps.push(`<div class="warn">Vyšlo \\(a=${latexNum(solvedValues.a)}\\,\\mathrm{m\\cdot s^{-2}}\\), což neodpovídá zvolenému režimu. Pro zrychlený pohyb má být \\(a>0\\), pro zpomalený \\(a<0\\).</div>`);
    return {ready:false, steps, missingInputs:[], solved:[]};
  }
  const checkV=solvedValues.v0+solvedValues.a*solvedValues.dt;
  const checkS=solvedValues.v0*solvedValues.dt+0.5*solvedValues.a*solvedValues.dt*solvedValues.dt;
  if(Math.abs(checkV-solvedValues.v)>0.02 || Math.abs(checkS-solvedValues.s)>0.02){
    steps.push(`<div class="warn">Zadané hodnoty si odporují. Z rovnice pro rychlost vychází \\(v=${latexNum(checkV)}\\,\\mathrm{m\\cdot s^{-1}}\\) a z rovnice pro dráhu \\(s=${latexNum(checkS)}\\,\\mathrm{m}\\), ale zadané/dopočítané hodnoty jsou jiné.</div>`);
    return {ready:false, steps, missingInputs:[], solved:[]};
  }
  for(const k of unknowns) setComputed(k, solvedValues[k]);

  const solvedText=unknowns.map(k=>labels[k][0]).join(', ');
  let n = simplified ? 3 : 2;
  if(unknowns.length===1){
    const rows=oneUnknownRows(unknowns[0]);
    steps.push(`<div class="step"><b>${n++}) Vyjádření neznámé ${solvedText} krok za krokem</b>${derivationHtml(rows)}</div>`);
    steps.push(`<div class="step"><b>${n++}) Dosazení</b>${substitutionHtml(unknowns, solvedValues)}</div>`);
  }else{
    const rows=twoUnknownWorkedRows(unknowns, solvedValues);
    steps.push(`<div class="step"><b>${n++}) Postup výpočtu neznámých ${solvedText}</b>${derivationHtml(rows)}</div>`);
  }
  steps.push(`<div class="step"><b>${n}) Kontrola v obou rovnicích</b>${checkHtml(solvedValues)}</div>`);
  return {ready:true, steps, missingInputs:[], solved:unknowns};
}
function substitutionHtml(unknowns, r){
  const pair=unknowns.slice().sort((x,y)=>visibleKeys().indexOf(x)-visibleKeys().indexOf(y)).join(',');
  const n=(x,d=2)=>latexNum(x,d);
  const t=x=>latexTerm(x,2);
  const v0=t(r.v0), a=t(r.a), dt=t(r.dt), v=t(r.v), s=t(r.s);
  const lines=[];
  const speedLine = () => hasZeroV0()
    ? `\\[v=a\\Delta t=${a}\\cdot ${dt}=${n(r.v)}${unitLatex('v')}\\]`
    : hasZeroV()
    ? `\\[0=v_0+a\\Delta t=${v0}+${a}\\cdot ${dt}=0\\,\\mathrm{m\\cdot s^{-1}}\\]`
    : `\\[v=v_0+a\\Delta t=${v0}+${a}\\cdot ${dt}=${n(r.v)}${unitLatex('v')}\\]`;
  const distanceLine = () => hasZeroV0()
    ? `\\[s=\\frac{1}{2}a(\\Delta t)^2=\\frac{1}{2}\\cdot ${a}\\cdot ${dt}^2=${n(r.s)}${unitLatex('s')}\\]`
    : `\\[s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2=${v0}\\cdot ${dt}+\\frac{1}{2}\\cdot ${a}\\cdot ${dt}^2=${n(r.s)}${unitLatex('s')}\\]`;
  const accelFromSpeed = () => hasZeroV0()
    ? `\\[a=\\frac{v}{\\Delta t}=\\frac{${v}}{${dt}}=${n(r.a)}${unitLatex('a')}\\]`
    : hasZeroV()
    ? `\\[a=-\\frac{v_0}{\\Delta t}=-\\frac{${v0}}{${dt}}=${n(r.a)}${unitLatex('a')}\\]`
    : `\\[a=\\frac{v-v_0}{\\Delta t}=\\frac{${v}-${v0}}{${dt}}=${n(r.a)}${unitLatex('a')}\\]`;
  const accelFromDistance = () => hasZeroV0()
    ? `\\[a=\\frac{2s}{(\\Delta t)^2}=\\frac{2\\cdot ${s}}{${dt}^2}=${n(r.a)}${unitLatex('a')}\\]`
    : `\\[a=\\frac{2(s-v_0\\Delta t)}{(\\Delta t)^2}=\\frac{2\\cdot(${s}-${v0}\\cdot ${dt})}{${dt}^2}=${n(r.a)}${unitLatex('a')}\\]`;
  const v0FromSpeed = () => hasZeroV()
    ? `\\[v_0=-a\\Delta t=-${a}\\cdot ${dt}=${n(r.v0)}${unitLatex('v0')}\\]`
    : `\\[v_0=v-a\\Delta t=${v}-${a}\\cdot ${dt}=${n(r.v0)}${unitLatex('v0')}\\]`;
  const v0FromDistance = () => `\\[v_0=\\frac{s-\\frac{1}{2}a(\\Delta t)^2}{\\Delta t}=\\frac{${s}-\\frac{1}{2}\\cdot ${a}\\cdot ${dt}^2}{${dt}}=${n(r.v0)}${unitLatex('v0')}\\]`;
  const timeFromSpeed = () => hasZeroV0()
    ? `\\[\\Delta t=\\frac{v}{a}=\\frac{${v}}{${a}}=${n(r.dt)}${unitLatex('dt')}\\]`
    : hasZeroV()
    ? `\\[\\Delta t=-\\frac{v_0}{a}=-\\frac{${v0}}{${a}}=${n(r.dt)}${unitLatex('dt')}\\]`
    : `\\[\\Delta t=\\frac{v-v_0}{a}=\\frac{${v}-${v0}}{${a}}=${n(r.dt)}${unitLatex('dt')}\\]`;
  const timeFromAverageSpeed = () => hasZeroV0()
    ? `\\[\\Delta t=\\frac{2s}{v}=\\frac{2\\cdot ${s}}{${v}}=${n(r.dt)}${unitLatex('dt')}\\]`
    : `\\[\\Delta t=\\frac{2s}{v_0+v}=\\frac{2\\cdot ${s}}{${v0}+${v}}=${n(r.dt)}${unitLatex('dt')}\\]`;
  const timeFromStopBySubstitution = () =>
    `\\[a=-\\frac{v_0}{\\Delta t}\\]`+
    `\\[s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2=${v0}\\cdot\\Delta t+\\frac{1}{2}\\left(-\\frac{${v0}}{\\Delta t}\\right)(\\Delta t)^2=\\frac{1}{2}\\cdot ${v0}\\cdot\\Delta t\\]`+
    `\\[\\Delta t=\\frac{2s}{v_0}=\\frac{2\\cdot ${s}}{${v0}}=${n(r.dt)}${unitLatex('dt')}\\]`;
  const timeFromDistanceZero = () => `\\[\\Delta t=\\sqrt{\\frac{2s}{a}}=\\sqrt{\\frac{2\\cdot ${s}}{${a}}}=${n(r.dt)}${unitLatex('dt')}\\]`;
  const timeFromStopDistance = () => `\\[\\Delta t=\\sqrt{-\\frac{2s}{a}}=\\sqrt{-\\frac{2\\cdot ${s}}{${a}}}=${n(r.dt)}${unitLatex('dt')}\\]`;
  const accelFromV0Pair = () => `\\[a=\\frac{2(v\\Delta t-s)}{(\\Delta t)^2}=\\frac{2\\cdot(${v}\\cdot ${dt}-${s})}{${dt}^2}=${n(r.a)}${unitLatex('a')}\\]`;
  const accelFromStopDistance = () => `\\[a=-\\frac{2s}{(\\Delta t)^2}=-\\frac{2\\cdot ${s}}{${dt}^2}=${n(r.a)}${unitLatex('a')}\\]`;

  if(unknowns.length===1){
    const x=unknowns[0];
    if(x==='a') lines.push(accelFromSpeed());
    if(x==='v') lines.push(speedLine());
    if(x==='s') lines.push(distanceLine());
    if(x==='dt') lines.push(hasZeroV0() ? timeFromDistanceZero() : timeFromSpeed());
    if(x==='v0') lines.push(v0FromSpeed());
    return lines.join('');
  }

  if(pair==='a,v'){
    lines.push(accelFromDistance(), speedLine());
  }else if(pair==='a,s'){
    lines.push(accelFromSpeed(), distanceLine());
  }else if(pair==='a,dt'){
    lines.push(hasZeroV() ? timeFromStopBySubstitution() : timeFromAverageSpeed(), accelFromSpeed());
  }else if(pair==='v0,a'){
    lines.push(hasZeroV() ? accelFromStopDistance() : accelFromV0Pair(), v0FromSpeed());
  }else if(pair==='v,s'){
    lines.push(speedLine(), distanceLine());
  }else if(pair==='dt,v'){
    lines.push(hasZeroV0() ? timeFromDistanceZero() : quadraticSubstitutionHtml(0.5*r.a, r.v0, -r.s, r.dt));
    lines.push(speedLine());
  }else if(pair==='dt,s'){
    lines.push(timeFromSpeed(), distanceLine());
  }else if(pair==='v0,v'){
    lines.push(v0FromDistance(), speedLine());
  }else if(pair==='v0,s'){
    lines.push(v0FromSpeed(), distanceLine());
  }else if(pair==='v0,dt'){
    lines.push(hasZeroV() ? timeFromStopDistance() : quadraticSubstitutionHtml(0.5*r.a, -r.v, r.s, r.dt));
    lines.push(v0FromSpeed());
  }
  return lines.join('');
}
function quadraticSubstitutionHtml(A,B,C, chosen){
  const D=B*B-4*A*C;
  const roots=solveQuadratic(A,B,C);
  const r1=roots[0], r2=roots[1] ?? roots[0];
  const chosenText=latexNum(chosen);
  if(Math.abs(A)<1e-12){
    return `\\[b\\Delta t+c=0\\]`+
           `\\[${latexTerm(B)}\\Delta t${signedQuadTerm(C)}=0\\]`+
           `\\[b=${latexNum(B)},\\quad c=${latexNum(C)}\\]`+
           `\\[\\Delta t=-\\frac{c}{b}=-\\frac{${latexTerm(C)}}{${latexTerm(B)}}=${chosenText}${unitLatex('dt')}\\]`;
  }
  return `\\[a(\\Delta t)^2+b\\Delta t+c=0\\]`+
         `\\[${quadraticPolynomial(A,B,C)}\\]`+
         `\\[a=${latexNum(A)},\\quad b=${latexNum(B)},\\quad c=${latexNum(C)}\\]`+
         `\\[\\Delta t_{1,2}=\\frac{-b\\pm\\sqrt{b^2-4ac}}{2a}=\\frac{-${latexTerm(B)}\\pm\\sqrt{${latexTerm(B)}^2-4\\cdot ${latexTerm(A)}\\cdot ${latexTerm(C)}}}{2\\cdot ${latexTerm(A)}}\\]`+
         `\\[\\Delta t_1=${latexNum(r1)}\\,\\mathrm{s},\\quad \\Delta t_2=${latexNum(r2)}\\,\\mathrm{s}\\]`+
         `\\[\\Delta t=${chosenText}\\,\\mathrm{s}\\quad\\text{bereme kladný čas}\\]`;
}
function checkHtml(r){
  const a=latexTerm(r.a,2), t=latexTerm(r.dt), v0=latexTerm(r.v0);
  if(hasZeroV0()){
    return `\\[v=a\\Delta t=${a}\\cdot ${t}=${latexNum(r.v)}\\,\\mathrm{m\\cdot s^{-1}}\\]`+
           `\\[s=\\frac{1}{2}a(\\Delta t)^2=\\frac{1}{2}\\cdot ${a}\\cdot ${t}^2=${latexNum(r.s)}\\,\\mathrm{m}\\]`;
  }
  return `\\[v=v_0+a\\Delta t=${v0}+${a}\\cdot ${t}=${latexNum(r.v)}\\,\\mathrm{m\\cdot s^{-1}}\\]`+
         `\\[s=v_0\\Delta t+\\frac{1}{2}a(\\Delta t)^2=${v0}\\cdot ${t}+\\frac{1}{2}\\cdot ${a}\\cdot ${t}^2=${latexNum(r.s)}\\,\\mathrm{m}\\]`;
}
function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }
function pick(arr){ return arr[Math.floor(Math.random()*arr.length)]; }
function resetValues(){ for(const k in values) delete values[k]; for(const k in computed) delete computed[k]; }
function fillObject(obj){
  resetValues();
  for(const [k,v] of Object.entries(obj)) values[k]=nice(v,2);
}
function generateRandomExample(){
  const c=cfg();
  const a=c.sign * (randInt(8,45)/10);
  let v0=0;
  let dt=randInt(15,70)/10;
  if(c.fixedV===0){
    v0=randInt(80,240)/10;
    dt=Math.abs(v0/a);
  }else if(c.fixedV0===null){
    if(a>0){
      v0=randInt(20,120)/10;
      dt=randInt(10,65)/10;
    }else{
      v0=randInt(100,240)/10;
      const maxT=Math.max(12, Math.floor((v0/Math.abs(a)-0.3)*10));
      dt=randInt(8, Math.min(maxT,70))/10;
    }
  }
  const obj={
    v0,
    a,
    dt,
    v:v0+a*dt,
    s:v0*dt+0.5*a*dt*dt
  };
  const keys=visibleKeys();
  const selected=currentUnknowns().filter(k=>keys.includes(k));
  const fallbackPairs = c.fixedV0===0
    ? [['a'],['v'],['s'],['dt'],['a','v'],['a','s'],['a','dt'],['v','s'],['dt','v'],['dt','s']]
    : (c.fixedV===0
      ? [['a'],['s'],['dt'],['v0'],['a','s'],['a','dt'],['v0','a'],['dt','s'],['v0','s'],['v0','dt']]
      : [['a'],['v'],['s'],['dt'],['v0'],['a','v'],['a','s'],['a','dt'],['v0','a'],['v','s'],['dt','v'],['dt','s'],['v0','v'],['v0','s'],['v0','dt']]);
  const missing = selected.length ? selected : pick(fallbackPairs);
  fillObject(obj);
  unknownsByMode[mode]=missing;
  for(const k of missing){ delete values[k]; delete computed[k]; }
  renderFields();
  calculate();
}
function typesetMath(){
 const nodes = [$('steps'), $('equation')].filter(Boolean);
 if(window.MathJax && MathJax.typesetPromise){
   try{ if(MathJax.typesetClear) MathJax.typesetClear(nodes); }catch(e){}
   MathJax.typesetPromise(nodes).catch(err=>console.warn('MathJax typeset failed:', err));
 }
}
window.typesetMath = typesetMath;
function renderFieldsPreserveFocus(){
 const active=document.activeElement;
 const id=active&&active.id;
 const pos=active&&active.selectionStart;
 renderFields();
 if(id && $(id) && !currentUnknowns().includes(id) && !computed[id]){
   $(id).focus();
   try{$(id).setSelectionRange(pos,pos)}catch(e){}
 }
}
function calculate(){
 const r=solveMotion();
 renderFieldsPreserveFocus();
 const u=currentUnknowns();
 const names=u.map(k=>labels[k][0]).join(', ');
 $('status').textContent = r.ready ? `Dopočítaná neznámá: ${names}` : `Zatím chybí hodnoty pro ${names}`;
 const aLabel = currentUnknowns().includes('a') ? 'a je neznámé' : (val('a')==null ? 'a není zadáno' : `a = ${fmt(val('a'))} m·s⁻²`);
 $('equation').innerHTML = `<span class="pill">${cfg().name}</span><span class="pill">${aLabel}</span><span class="pill">neznámé: ${names}</span>`;
 const missing = (r.missingInputs && r.missingInputs.length) ? ` Chybí ještě: ${r.missingInputs.map(k=>labels[k][0]).join(', ')}.` : '';
 $('steps').innerHTML = r.steps.join('') + (!r.ready?`<div class="warn">Zaškrtni jednu nebo dvě neznámé a doplň ostatní hodnoty.${missing}</div>`:'');
 typesetMath();
}
$('randomExample').onclick=generateRandomExample;
$('clearAll').onclick=clearAll;
renderModes();
renderFields();
calculate();
window.addEventListener('load', () => setTimeout(typesetMath, 0));
</script>
</body>
</html>
